# /etc/portage/env/compiler-clang-linuxkernel

COMMON_FLAGS="-march=native -O2 -pipe"

CFLAGS="${COMMON_FLAGS}"
CXXFLAGS="${COMMON_FLAGS}"
FCFLAGS="${COMMON_FLAGS}"
FFLAGS="${COMMON_FLAGS}"

CC="clang"
CPP="clang-cpp"
CXX="clang++"

AR="llvm-ar"
NM="llvm-nm"
RANLIB="llvm-ranlib"

OBJCOPY="llvm-objcopy"
OBJDUMP="llvm-objdump"
READELF="llvm-readelf"
STRIP="llvm-strip"

LD="ld.lld"
LDFLAGS="-fuse-ld=lld"