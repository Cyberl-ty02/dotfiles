# GCC fallback profile for packages that do not build cleanly with clang/LLVM.
# Keep this conservative. Do not add LTO or mold here.

# Generated/resolved for the current Lenovo Legion CPU.
# If this config is copied to another machine, replace this with -march=native.
RESOLVE_MARCH_FLAGS="-march=alderlake -mabm -mno-kl -mno-pconfig -mno-sgx -mno-widekl -mshstk"
COMMON_FLAGS="${RESOLVE_MARCH_FLAGS} -O2 -pipe"

CFLAGS="${COMMON_FLAGS}"
CXXFLAGS="${COMMON_FLAGS}"
FCFLAGS="${COMMON_FLAGS}"
FFLAGS="${COMMON_FLAGS}"

# Safe linker flags for GCC fallback builds.
LDFLAGS="-Wl,-O1 -Wl,--as-needed"

CC="gcc"
CXX="g++"
CPP="gcc -E"

AR="ar"
LD="ld"
NM="nm"
OBJCOPY="objcopy"
OBJDUMP="objdump"
RANLIB="ranlib"
READELF="readelf"
STRIP="strip"