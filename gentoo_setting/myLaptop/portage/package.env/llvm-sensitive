# LLVM/Clang/runtime stack: avoid experimental global linker flags here.
# This is intentionally not forced to GCC; it only avoids mold and reduces jobs.
llvm-core/llvm no-mold lowjobs
llvm-core/clang no-mold lowjobs
llvm-core/lld no-mold lowjobs
llvm-runtimes/compiler-rt no-mold lowjobs
llvm-runtimes/clang-runtime no-mold lowjobs
llvm-runtimes/openmp no-mold lowjobs

# C library / binutils: keep the linker path conservative.
sys-libs/glibc no-mold lowjobs
sys-devel/binutils no-mold