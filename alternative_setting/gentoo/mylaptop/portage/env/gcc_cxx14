# For old C++ packages that still use APIs removed after C++14, e.g. std::random_shuffle.
CFLAGS="-march=native -O2 -pipe"
CXXFLAGS="-march=native -O2 -pipe -std=gnu++14"
FCFLAGS="-march=native -O2 -pipe"
FFLAGS="-march=native -O2 -pipe"
LDFLAGS="-Wl,-O1 -Wl,--as-needed -Wl,-z,pack-relative-relocs"
CC="gcc"
CXX="g++"
CPP="gcc -E"
AR="ar"
LD="ld"
NM="nm"
OBJCOPY="objcopy"
OBJDUMP="objdump"
RANLIB="ranlib"
READELF="readelf"
STRIP="strip"
